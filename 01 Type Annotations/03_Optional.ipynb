   "source": [
    "from typing import Optional\n",
    "\n",
    "def nice_message(name: Optional[str]) -> None:\n",
    "    if name is None:\n",
    "        print(\"Hello, random person!\")\n",
    "\n",
    "    else:\n",
    "        print(f\"Hello, {name}!\")\n",
    "\n",
    "nice_message(\"Alice\")\n",
    "nice_message(None)"
   ]
  },
